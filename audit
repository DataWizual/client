#!/bin/bash
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="$PROJECT_ROOT:$PYTHONPATH"

if [ "$#" -eq 0 ]; then
    echo "Usage: ./audit <target_path> [options]"
    exit 1
fi

TARGET="$1"
shift

if [ ! -e "$TARGET" ]; then
    echo "Error: Target path '$TARGET' does not exist."
    exit 1
fi

if [ -d "$PROJECT_ROOT/venv" ]; then
    source "$PROJECT_ROOT/venv/bin/activate"
fi

echo -e "\033[0;33m🧹 Deep cleaning bytecode cache in all directories...\033[0m"
find "$PROJECT_ROOT" -path "$PROJECT_ROOT/venv" -prune -o -name "*.pyc" -depth -delete
find "$PROJECT_ROOT" -path "$PROJECT_ROOT/venv" -prune -o -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null

echo -e "\033[0;32m🚀 Starting Auditor Core Professional...\033[0m"

python3 "$PROJECT_ROOT/orchestrator.py" "$TARGET" --config "$PROJECT_ROOT/audit-config.yml" "$@"