# ============================================================
# Sentinel Core — Environment Configuration
# Скопируй в .env и заполни своими значениями
# ============================================================
AUDITOR_LICENSE_SALT="A8#kL2!pZ97_qrXvW-mN5@bYt4*QeR9"
# --- Licensing ---
# Уникальный ключ привязанный к Machine ID
# Получить Machine ID: sentinel --id
SENTINEL_LICENSE_KEY=YOUR_LICENSE_KEY_HERE
AUDITOR_LICENSE_KEY=YOUR_LICENSE_KEY_HERE   # тот же ключ

# --- Sentinel Shield (GitHub Integration) ---
# PAT с правами issues:write для отчётов о нарушениях
SENTINEL_ALERT_TOKEN=YOUR_GITHUB_TOKEN_HERE
# Формат: ваш_org/sentinel-core
SENTINEL_ADMIN_REPO=YourOrg/sentinel-core

# --- AI Advisory (Google Gemini) ---
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE
GOOGLE_MODEL=gemini-2.5-flash

# --- Sentinel AI (опционально, для встроенного AI в Sentinel) ---
# Оставь пустым если используешь только Gemini через Auditor Core
SENTINEL_AI_KEY=
SENTINEL_AI_URL=https://api.groq.com/openai/v1/chat/completions
SENTINEL_AI_MODEL=llama-3.3-70b-versatile

# --- Scanner Limits ---
MAX_FINDINGS=5000
MAX_FILE_SIZE=1048576

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

