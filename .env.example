# --- Database Configuration ---
# These must match the values in docker-compose.yml
DB_USER=auditor
DB_NAME=auditor_pro
DB_PASSWORD=SET_STRONG_PASSWORD_HERE

# AUDITOR_LICENSE_SALT="SALT_KEY"

# --- Security & Licensing ---
# Unique key generated for the specific Machine ID
AUDITOR_LICENSE_KEY=YOUR_LICENSE_KEY_HERE

# Connection string for the Orchestrator
# Use 'postgres' as host when running inside Docker
AUDITOR_DB_URL=postgresql://auditor:SET_STRONG_PASSWORD_HERE@127.0.0.1:5432/auditor_pro
ALLOW_INIT_DB=true

# --- AI Remediation (Google Gemini Integration) ---
# RCA Item 8: External provider configuration
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GOOGLE_MODEL=gemini-2.5-flash

# --- Scanner Performance & Limits ---
# RCA Item 13: Memory and report size protection
MAX_FINDINGS=5000
MAX_FILE_SIZE=1048576

# --- Logging & Debug ---
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- AI Fallback (Groq) ---
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile
